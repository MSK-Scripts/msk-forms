# ──────────────────────────────────────────────────────────────
# MSK Forms — environment template
# Copy to .env and fill in the values. NEVER commit .env!
# ──────────────────────────────────────────────────────────────

# App
NODE_ENV=development
APP_URL=http://localhost:3000
PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://msk:msk@localhost:5432/msk_forms?schema=public

# Redis (sessions, queue, rate limiting)
REDIS_URL=redis://localhost:6379

# Session / crypto (32-byte hex)
SESSION_SECRET=

# Discord OAuth2 + bot
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback

# Internal bot <-> web signing (HMAC)
INTERNAL_WEBHOOK_SECRET=

# Object storage (S3 / MinIO)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=msk-forms
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=eu-central-1

# Mail (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@msk-scripts.de

# Captcha — Cloudflare Turnstile (both keys required to enable it on public forms)
CAPTCHA_SITE_KEY=
CAPTCHA_SECRET_KEY=
