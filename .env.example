# ──────────────────────────────────────────────────────────────
# MSK Forms — Environment-Vorlage
# Kopieren nach .env und Werte einsetzen. NIEMALS .env committen!
# ──────────────────────────────────────────────────────────────

# App
NODE_ENV=development
APP_URL=http://localhost:3000
PORT=3000

# Datenbank (PostgreSQL)
DATABASE_URL=postgresql://msk:msk@localhost:5432/msk_forms?schema=public

# Redis (Sessions, Queue, Rate-Limit)
REDIS_URL=redis://localhost:6379

# Session / Crypto (32-byte hex)
SESSION_SECRET=

# Discord OAuth2 + Bot
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback

# Interne Bot ↔ Web Signierung (HMAC)
INTERNAL_WEBHOOK_SECRET=

# Object Storage (S3 / MinIO)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=msk-forms
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=eu-central-1

# Mail (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@msk-scripts.de

# Captcha (hCaptcha / Cloudflare Turnstile)
CAPTCHA_SITE_KEY=
CAPTCHA_SECRET_KEY=
