// MSK Forms — Prisma schema
// Data model per concept §15. DB: PostgreSQL.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────

enum Plan {
  free
  pro
  enterprise
}

enum GuildRole {
  owner
  admin
  reviewer
  viewer
}

enum FormMode {
  application
  survey
  contact
  quiz
}

enum FormStatus {
  draft
  live
  closed
  archived
}

enum FormVisibility {
  public
  authenticated
  password
  role_required
}

enum SubmissionEventType {
  status_change
  note
  message
  reminder
  info_request
  info_reply
}

enum EventVisibility {
  public
  internal
}

// ─────────────────────────────────────────────────────────────
// Core entities
// ─────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid()) @db.Uuid
  discordId String   @unique @map("discord_id")
  username  String
  avatar    String?
  email     String?
  locale    String   @default("de")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberships   GuildMember[]
  submissions   Submission[]
  createdForms  Form[]              @relation("FormCreatedBy")
  events        SubmissionEvent[]
  notifications Notification[]
  formReviews   FormReviewer[]

  @@map("users")
}

model Guild {
  id             String   @id @default(uuid()) @db.Uuid
  discordGuildId String   @unique @map("discord_guild_id")
  name           String
  icon           String?
  ownerUserId    String   @map("owner_user_id") @db.Uuid
  plan           Plan     @default(free)
  grandfathered  Boolean  @default(false)
  stripeCustomerId     String? @unique @map("stripe_customer_id")
  stripeSubscriptionId String? @map("stripe_subscription_id")
  branding       Json     @default("{}")
  botConfig      Json     @default("{}") @map("bot_config")
  /// Vanity hub handle on the primary domain: forms.msk-scripts.de/<handle>.
  handle                 String?   @unique
  customDomain           String?   @unique @map("custom_domain")
  customDomainToken      String?   @map("custom_domain_token")
  customDomainVerifiedAt DateTime? @map("custom_domain_verified_at")
  /// Per-guild Discord OAuth app (for login on the guild's own custom domain).
  /// The client secret is stored encrypted (AES-256-GCM, see lib/crypto.ts).
  oauthClientId     String? @map("oauth_client_id")
  oauthClientSecret String? @map("oauth_client_secret")
  /// Per-guild Cloudflare Turnstile (captcha) for forms on the custom domain.
  /// The secret is stored encrypted; the site key is public.
  captchaSiteKey String? @map("captcha_site_key")
  captchaSecret  String? @map("captcha_secret")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  members       GuildMember[]
  forms         Form[]
  submissions   Submission[]
  formStatuses  FormStatusDef[]
  categories    FormCategory[]
  apiKeys       ApiKey[]
  notifications Notification[]
  webhooks      Webhook[]

  @@map("guilds")
}

model GuildMember {
  guildId String    @map("guild_id") @db.Uuid
  userId  String    @map("user_id") @db.Uuid
  role    GuildRole @default(viewer)

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([guildId, userId])
  @@index([userId])
  @@map("guild_members")
}

/// Per-form reviewer grant: lets a member (typically a viewer) review a specific
/// form's submissions without being a guild-wide reviewer.
model FormReviewer {
  formId    String   @map("form_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([formId, userId])
  @@index([userId])
  @@map("form_reviewers")
}

model Form {
  id          String         @id @default(uuid()) @db.Uuid
  guildId     String         @map("guild_id") @db.Uuid
  slug        String         @unique
  title       String
  description String?
  mode        FormMode       @default(application)
  status      FormStatus     @default(draft)
  visibility  FormVisibility @default(authenticated)
  schema      Json           @default("{}")
  settings    Json           @default("{}")
  theme       Json           @default("{}")
  version     Int            @default(1)
  openAt      DateTime?      @map("open_at")
  closeAt     DateTime?      @map("close_at")
  categoryId  String?        @map("category_id") @db.Uuid
  createdById String         @map("created_by") @db.Uuid
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  guild        Guild           @relation(fields: [guildId], references: [id], onDelete: Cascade)
  category     FormCategory?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy    User            @relation("FormCreatedBy", fields: [createdById], references: [id])
  versions     FormVersion[]
  submissions  Submission[]
  formStatuses FormStatusDef[]
  reviewers    FormReviewer[]
  experimentStats ExperimentStat[]

  @@index([guildId, status])
  @@index([guildId, categoryId])
  @@map("forms")
}

/// Per-guild form category (e.g. "Job applications" vs "Staff applications").
/// Forms reference it optionally; deleting a category leaves its forms
/// uncategorized (SetNull). Public hubs group live forms by category.
model FormCategory {
  id        String   @id @default(uuid()) @db.Uuid
  guildId   String   @map("guild_id") @db.Uuid
  name      String
  color     String?
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  guild Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  forms Form[]

  @@index([guildId])
  @@map("form_categories")
}

/// Per-variant A/B test counters for a form (concept §26): views (assignments)
/// and submissions (conversions). One row per (form, variant).
model ExperimentStat {
  id          String   @id @default(uuid()) @db.Uuid
  formId      String   @map("form_id") @db.Uuid
  variantId   String   @map("variant_id")
  views       Int      @default(0)
  submissions Int      @default(0)
  updatedAt   DateTime @updatedAt @map("updated_at")

  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@unique([formId, variantId])
  @@map("experiment_stats")
}

model FormVersion {
  id        String   @id @default(uuid()) @db.Uuid
  formId    String   @map("form_id") @db.Uuid
  version   Int
  schema    Json
  settings  Json
  createdAt DateTime @default(now()) @map("created_at")

  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@unique([formId, version])
  @@map("form_versions")
}

model FormStatusDef {
  id                 String  @id @default(uuid()) @db.Uuid
  guildId            String  @map("guild_id") @db.Uuid
  formId             String? @map("form_id") @db.Uuid
  key                String
  label              String
  color              String  @default("#6b6b72")
  order              Int     @default(0)
  visibleToApplicant Boolean @default(true) @map("visible_to_applicant")
  isTerminal         Boolean @default(false) @map("is_terminal")

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
  form  Form? @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@unique([guildId, formId, key])
  @@map("form_statuses")
}

model Submission {
  id          String   @id @default(uuid()) @db.Uuid // = UUID link
  formId      String   @map("form_id") @db.Uuid
  guildId     String   @map("guild_id") @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  answers     Json     @default("{}")
  status      String   @default("submitted")
  score       Int?
  meta        Json     @default("{}")
  submittedAt DateTime @default(now()) @map("submitted_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  form   Form              @relation(fields: [formId], references: [id], onDelete: Cascade)
  guild  Guild             @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user   User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  events SubmissionEvent[]
  files  FileUpload[]

  @@index([formId, status])
  @@index([userId])
  @@index([guildId, submittedAt])
  @@map("submissions")
}

model SubmissionEvent {
  id           String              @id @default(uuid()) @db.Uuid
  submissionId String              @map("submission_id") @db.Uuid
  actorUserId  String?             @map("actor_user_id") @db.Uuid
  type         SubmissionEventType
  fromStatus   String?             @map("from_status")
  toStatus     String?             @map("to_status")
  message      String?
  visibility   EventVisibility     @default(internal)
  createdAt    DateTime            @default(now()) @map("created_at")

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  actor      User?      @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([submissionId, createdAt])
  @@map("submission_events")
}

model FileUpload {
  id           String   @id @default(uuid()) @db.Uuid
  submissionId String   @map("submission_id") @db.Uuid
  fieldId      String   @map("field_id")
  filename     String
  mime         String
  size         Int
  storageKey   String   @map("storage_key")
  scanned      Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("files")
}

model Notification {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String?   @map("user_id") @db.Uuid
  guildId   String?   @map("guild_id") @db.Uuid
  type      String
  payload   Json      @default("{}")
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user  User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  guild Guild? @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([guildId, readAt])
  @@map("notifications")
}

model ApiKey {
  id         String    @id @default(uuid()) @db.Uuid
  guildId    String    @map("guild_id") @db.Uuid
  name       String
  hashedKey  String    @unique @map("hashed_key")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

/// Outgoing webhook endpoint registered by a guild (concept §20). Fires on the
/// subscribed events; deliveries are queued as WebhookDelivery rows and sent by
/// the bot's outbox poller (HMAC-signed with `secret`).
model Webhook {
  id        String   @id @default(uuid()) @db.Uuid
  guildId   String   @map("guild_id") @db.Uuid
  url       String
  secret    String
  events    String[]
  active    Boolean  @default(true)
  /// Who manages this hook: "manual" (dashboard) or an integration ("zapier"/"make").
  source    String   @default("manual")
  createdAt DateTime @default(now()) @map("created_at")

  guild      Guild             @relation(fields: [guildId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([guildId])
  @@map("webhooks")
}

/// One queued delivery of an event to a webhook endpoint. The poller picks up
/// `pending` rows whose `nextAttemptAt` is due, POSTs the signed payload, and
/// marks them `success` or (after MAX_ATTEMPTS) `failed` with `lastError`.
model WebhookDelivery {
  id            String    @id @default(uuid()) @db.Uuid
  webhookId     String    @map("webhook_id") @db.Uuid
  event         String
  payload       Json      @default("{}")
  status        String    @default("pending")
  attempts      Int       @default(0)
  lastError     String?   @map("last_error")
  nextAttemptAt DateTime  @default(now()) @map("next_attempt_at")
  deliveredAt   DateTime? @map("delivered_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([status, nextAttemptAt])
  @@map("webhook_deliveries")
}
